{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/cli.ts",
    "src/commands/*.ts",
    "src/cs/commands/*.ts",
    "src/betting/commands/*.ts",
    "src/betting/listeners/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.test.ts",
    "tests/preload.ts"
  ],
  "project": ["src/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "admin/**/*.{ts,tsx}"],
  "ignoreDependencies": ["pino-pretty", "drizzle-kit"],
  "rules": {
    "types": "off",
    "enumMembers": "off",
    "duplicates": "off"
  }
}
