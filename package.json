{
  "name": "jomify",
  "version": "1.0.0",
  "author": "Jom",
  "dependencies": {
    "discord.js": "^14.26.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "description": "CS2 stats Discord bot powered by Leetify",
  "keywords": ["discord", "cs2", "leetify", "stats"],
  "license": "MIT",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "register": "bun run src/register.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "knip": "knip",
    "check": "bun run typecheck && bun run lint && bun run knip"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "1.3.12",
    "knip": "6.4.1"
  }
}
