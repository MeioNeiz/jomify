{
  "name": "jomify",
  "version": "1.0.0",
  "author": "Jom",
  "dependencies": {
    "@csfloat/cs2-inspect-serializer": "^1.1.6",
    "discord.js": "^14.26.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "description": "CS2 stats Discord bot powered by Leetify",
  "keywords": [
    "discord",
    "cs2",
    "leetify",
    "stats"
  ],
  "license": "MIT",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "admin": "bun run admin/index.ts",
    "admin:dev": "bun --watch admin/index.ts",
    "register": "bun run src/register.ts",
    "register:clean": "bun run scripts/register-clean.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "knip": "knip",
    "check": "bun run typecheck && bun run lint && bun run knip",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "1.3.12",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "knip": "6.4.1"
  }
}
